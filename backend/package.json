{
  "name": "sovereon-backend",
  "version": "1.0.0",
  "description": "Sovereon Inc. Backend API",
  "main": "dist/app.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:with-migrate": "npx prisma migrate deploy && npx prisma generate && node dist/app.js",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "ts-node src/database/seed.ts",
    "seed:cms": "ts-node src/database/seed-cms.ts",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "Sovereon Inc.",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express-session": "^1.18.2",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^2.4.0",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^8.0.1",
    "uuid": "^9.0.0",
    "zod": "^3.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
