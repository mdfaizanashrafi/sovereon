# Database (PostgreSQL for both dev and production)
DATABASE_URL=postgresql://username:password@localhost:5432/sovereon

# Admin Session Secret (Required for admin panel)
SESSION_SECRET=your-super-secret-session-key-change-this

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (Resend API)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Sovereon <partners@sovereon.online>
ADMIN_EMAIL=partners@sovereon.online

# Logging
LOG_LEVEL=debug
